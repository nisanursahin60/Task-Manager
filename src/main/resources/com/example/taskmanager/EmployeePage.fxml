<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.TilePane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>

<AnchorPane fx:id="anchorPane"
            prefHeight="600.0" prefWidth="900.0"
            stylesheets="@style.css"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.taskmanager.controller.EmployeePageController">
    <children>
        <HBox AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0"
              AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">

            <VBox fx:id="sidePanel" prefWidth="240" spacing="18" styleClass="side-panel">
                <HBox spacing="12" styleClass="profile-box">
                    <StackPane styleClass="avatar-circle">
                        <Label fx:id="avatarLabel" text="?" styleClass="avatar-letter"/>
                    </StackPane>
                    <VBox spacing="3">
                        <Label fx:id="profilRolLabel" text="Çalışan" styleClass="small-text"/>
                        <Label fx:id="profilAdLabel" text="..." styleClass="profile-name"/>
                    </VBox>
                </HBox>

                <Separator styleClass="side-separator"/>

                <VBox spacing="8">
                    <HBox spacing="8" styleClass="menu-item" onMouseClicked="#tumGorevleriGoster">
                        <Label text="▾" styleClass="arrow"/>
                        <Label text="Görevlerim" styleClass="menu-text"/>
                    </HBox>

                    <VBox spacing="6" styleClass="sub-menu">

                        <HBox spacing="10" styleClass="sub-menu-item" onMouseClicked="#sonTarihYaklasanlar" alignment="CENTER_LEFT">
                            <ImageView fitHeight="16" fitWidth="16" preserveRatio="true">
                                <Image url="@images/upcoming.png" />
                            </ImageView>
                            <Label text="Yaklaşanlar" styleClass="menu-text" style="-fx-text-fill: white;"/>
                        </HBox>

                        <HBox spacing="10" styleClass="sub-menu-item" onMouseClicked="#yeniGorevler" alignment="CENTER_LEFT">
                            <ImageView fitHeight="16" fitWidth="16" preserveRatio="true">
                                <Image url="@images/new.png" />
                            </ImageView>
                            <Label text="Yeni" styleClass="menu-text" style="-fx-text-fill: white;"/>
                            <Region HBox.hgrow="ALWAYS" />
                            <Label fx:id="yeniGorevNokta"
                                   visible="false"
                                   managed="false"
                                   style="-fx-background-color: #ef4444;
                  -fx-min-width: 8; -fx-min-height: 8;
                  -fx-max-width: 8; -fx-max-height: 8;
                  -fx-background-radius: 50;" />
                        </HBox>

                        <HBox spacing="10" styleClass="sub-menu-item" onMouseClicked="#yildizliGorevler" alignment="CENTER_LEFT">
                            <ImageView fitHeight="16" fitWidth="16" preserveRatio="true">
                                <Image url="@images/star.png" />
                            </ImageView>
                            <Label text="Yıldızlı" styleClass="menu-text" style="-fx-text-fill: white;"/>
                        </HBox>

                        <HBox spacing="10" styleClass="sub-menu-item" onMouseClicked="#tamamlananGorevler" alignment="CENTER_LEFT">
                            <ImageView fitHeight="16" fitWidth="16" preserveRatio="true">
                                <Image url="@images/checked.png" />
                            </ImageView>
                            <Label text="Tamamlananlar" styleClass="menu-text" style="-fx-text-fill: white;"/>
                        </HBox>

                    </VBox>
                </VBox>

                <Region VBox.vgrow="ALWAYS"/>

                <HBox spacing="8" styleClass="logout-box" onMouseClicked="#cikisYap">
                    <ImageView fitHeight="18" fitWidth="18" preserveRatio="true">
                        <Image url="@images/logout.png" />
                    </ImageView>
                    <Label text="Çıkış Yap" styleClass="logout-text"/>
                </HBox>
            </VBox>

            <VBox fx:id="mainPanel" spacing="22" styleClass="main-panel" HBox.hgrow="ALWAYS">
                <VBox spacing="6">
                    <Label fx:id="panelBaslik" text="TÜM GÖREVLERİM" styleClass="page-title"/>
                    <Label text="Tamamladığın adımları işaretlemeyi unutma." styleClass="page-subtitle"/>
                </VBox>

                <ScrollPane fitToWidth="true" styleClass="scroll-pane-clean">
                    <content>
                        <HBox fx:id="gorevKartAlani" spacing="20" styleClass="card-area">
                        </HBox>
                    </content>
                </ScrollPane>
            </VBox>
        </HBox>
    </children>
</AnchorPane>