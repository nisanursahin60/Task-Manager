<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="550.0" prefWidth="800.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="com.example.taskmanager.controller.TaskDetailPageController">
    <children>
        <HBox AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">

            <VBox minWidth="260.0" maxWidth="260.0" prefWidth="260.0" spacing="20.0" styleClass="side-panel">
                <padding>
                    <Insets bottom="25.0" left="20.0" right="20.0" top="25.0" />
                </padding>

                <HBox spacing="15" alignment="CENTER_LEFT">
                    <StackPane styleClass="avatar-circle">
                        <Label fx:id="managerAvatarLabel" text="Y" styleClass="avatar-letter"/>
                    </StackPane>
                    <VBox spacing="2">
                        <Label fx:id="managerNameLabel" text="Yönetici Adı" styleClass="profile-name"/>
                        <Label text="Proje Yöneticisi" styleClass="small-text"/>
                    </VBox>
                </HBox>

                <Separator styleClass="side-separator"/>

                <VBox spacing="10" VBox.vgrow="ALWAYS">
                    <Label text="Yöneticiye Soru Sor" style="-fx-font-weight: bold; -fx-text-fill: white;"/>
                    <TextArea fx:id="questionArea" promptText="Görevle ilgili aklına takılanları buraya yazabilirsin..." wrapText="true" VBox.vgrow="ALWAYS" style="-fx-background-radius: 8; -fx-control-inner-background: #ffffff;"/>

                    <Button text="Gönder" onAction="#handleSendQuestion" maxWidth="1.7976931348623157E308" style="-fx-background-color: #1d4ed8; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10; -fx-cursor: hand;"/>
                </VBox>

            </VBox>

            <!-- SAĞ PANEL: Görev Detayları ve Dosyalar -->
            <VBox spacing="20.0" HBox.hgrow="ALWAYS" style="-fx-background-color: #f4f7fb;">
                <padding>
                    <Insets bottom="30.0" left="35.0" right="35.0" top="30.0" />
                </padding>
                <VBox spacing="5">
                    <Label fx:id="taskTitleLabel" text="GÖREV BAŞLIĞI" styleClass="page-title" wrapText="true"/>
                    <Label text="Görev Detayları" styleClass="page-subtitle"/>
                </VBox>

                <Separator style="-fx-opacity: 0.2; -fx-background-color: #1d4ed8;"/>

                <ScrollPane fitToWidth="true" styleClass="scroll-pane-clean" VBox.vgrow="ALWAYS">
                    <VBox spacing="20">
                        <Label fx:id="taskDescriptionLabel" text="Görev açıklaması burada yer alacak..." wrapText="true" style="-fx-font-size: 14.5px; -fx-text-fill: #1f2d3d; -fx-line-spacing: 1.5;"/>
                        <!-- Ekli Dosyalar Kutusu -->
                        <VBox fx:id="filesContainer" spacing="10">
                            <Label text="Ekli Dosyalar" style="-fx-font-weight: bold; -fx-text-fill: #7b8a9b;"/>
                            <!-- İçerik Java Controller tarafından buraya eklenecek -->
                        </VBox>
                    </VBox>
                </ScrollPane>
            </VBox>

        </HBox>
    </children>
</AnchorPane>