<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.TilePane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>

<AnchorPane fx:id="anchorPane"
            prefHeight="600.0"
            prefWidth="900.0"
            stylesheets="@style.css"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.taskmanager.controller.ManagerPageController">

    <children>
        <HBox AnchorPane.bottomAnchor="0"
              AnchorPane.leftAnchor="0"
              AnchorPane.rightAnchor="0"
              AnchorPane.topAnchor="0">

            <VBox fx:id="sidePanel" prefWidth="240" spacing="18" styleClass="side-panel">

                <HBox spacing="12" styleClass="profile-box">
                    <StackPane prefHeight="46" prefWidth="46" styleClass="avatar-circle">
                        <Label text="Y" styleClass="avatar-letter"/>
                    </StackPane>

                    <VBox spacing="3">
                        <Label text="Yönetici" styleClass="small-text"/>
                        <Label fx:id="profilLabel" text="Yönetici Adı" styleClass="profile-name"/>
                    </VBox>
                </HBox>

                <Separator styleClass="side-separator"/>

                <VBox spacing="8">
                    <HBox spacing="10" styleClass="menu-item" onMouseClicked="#tumCalisanlariGoster" alignment="CENTER_LEFT">
                        <ImageView fitHeight="18" fitWidth="18" preserveRatio="true">
                            <Image url="@images/staff.png" />
                        </ImageView>
                        <Label text="Çalışanlar" styleClass="menu-text"/>
                    </HBox>

                    <VBox fx:id="departmanListesi" spacing="6" styleClass="sub-menu">
                        <Label text="Muhasebe" styleClass="sub-menu-item" onMouseClicked="#muhasebeGoster"/>
                        <Label text="Yazılım" styleClass="sub-menu-item" onMouseClicked="#yazilimGoster"/>
                        <Label text="İnsan Kaynakları" styleClass="sub-menu-item" onMouseClicked="#ikGoster"/>
                        <Label text="Pazarlama" styleClass="sub-menu-item" onMouseClicked="#pazarlamaGoster"/>
                        <Label text="Destek" styleClass="sub-menu-item" onMouseClicked="#destekGoster"/>
                    </VBox>
                </VBox>

                <HBox spacing="10" styleClass="menu-item" onMouseClicked="#atananGorevleriGoster" alignment="CENTER_LEFT">
                    <ImageView fitHeight="18" fitWidth="18" preserveRatio="true">
                        <Image url="@images/push-pin.png" />
                    </ImageView>
                    <Label text="Atanan Görevler" styleClass="menu-text"/>
                </HBox>

                <HBox spacing="10" styleClass="menu-item" onMouseClicked="#sorulanSorulariGoster" alignment="CENTER_LEFT">
                    <children>
                        <ImageView fitHeight="18.0" fitWidth="18.0" pickOnBounds="true" preserveRatio="true">
                            <Image url="@images/faq.png" />
                        </ImageView>
                        <Label text="Sorulan Sorular" styleClass="menu-text" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label fx:id="yeniMesajNoktasi" visible="false" managed="true"
                               style="-fx-background-color: #ef4444;
                                      -fx-min-width: 8; -fx-min-height: 8;
                                      -fx-max-width: 8; -fx-max-height: 8;
                                      -fx-background-radius: 50;">
                        </Label>
                    </children>
                </HBox>

                <Region VBox.vgrow="ALWAYS"/>

                <HBox spacing="8" styleClass="logout-box" onMouseClicked="#cikisYap">
                    <ImageView fitHeight="18" fitWidth="18" preserveRatio="true">
                        <Image url="@images/logout.png" />
                    </ImageView>
                    <Label text="Çıkış Yap" styleClass="logout-text"/>
                </HBox>

            </VBox>

            <VBox fx:id="mainPanel" spacing="22" styleClass="main-panel" HBox.hgrow="ALWAYS">

                <HBox alignment="CENTER_LEFT" spacing="15">
                    <VBox spacing="6">
                        <Label fx:id="departmanad" text="Tüm Çalışanlar" styleClass="page-title"/>
                        <Label fx:id="sayfaAciklamasi" text="Çalışan bilgilerini buradan görüntüleyebilirsin." styleClass="page-subtitle"/>
                    </VBox>

                    <Region HBox.hgrow="ALWAYS"/>

                    <HBox fx:id="aramaAlani" alignment="CENTER_LEFT">
                        <TextField fx:id="aramaCubugu"
                                   promptText="Çalışan ara..."
                                   styleClass="search-field"
                                   prefWidth="200"/>
                    </HBox>

                    <HBox spacing="6" styleClass="add-task-link" onMouseClicked="#gorevEklePaneliAc">
                        <Label text="+" styleClass="add-plus"/>
                        <Label text="Görev Ekle" styleClass="add-text"/>
                    </HBox>
                </HBox>

                <ScrollPane fitToWidth="true" styleClass="scroll-pane-clean" VBox.vgrow="ALWAYS">
                    <content>
                        <StackPane>
                            <TilePane fx:id="calisanKartAlani"
                                      hgap="18"
                                      vgap="18"
                                      prefColumns="3"
                                      styleClass="card-area"
                                      visible="true"
                                      managed="true"/>

                            <HBox fx:id="gorevSutunAlani"
                                  spacing="20"
                                  styleClass="card-area"
                                  visible="false"
                                  managed="false"
                                  alignment="TOP_LEFT">
                            </HBox>
                        </StackPane>
                    </content>
                </ScrollPane>

            </VBox>

        </HBox>
    </children>
</AnchorPane>